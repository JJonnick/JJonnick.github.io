---
import Content from "@/layouts/Content.astro";
import Layout from "@/layouts/Layout.astro";
import Chests from "@/components/Chests.astro";
import Oculis from "@/components/Oculis.astro";
import { getAccount } from "@/services/database";
import RowData from "@/components/RowData.astro";

const account = await getAccount();

if (!account) {
    return Astro.redirect("/404");
}

const toSafeNumber = (value: unknown): number => {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : 0;
};

const stats = account.stats;
const nickname = account.nickname?.trim() || "Viajero";
const level = toSafeNumber(account.level);

const chests = {
    common: toSafeNumber(stats?.common_chests),
    exquisite: toSafeNumber(stats?.exquisite_chests),
    precious: toSafeNumber(stats?.precious_chests),
    luxurious: toSafeNumber(stats?.luxurious_chests),
};

const oculis = {
    anemo: toSafeNumber(stats?.anemoculi),
    geo: toSafeNumber(stats?.geoculi),
    electro: toSafeNumber(stats?.electroculi),
    dendro: toSafeNumber(stats?.dendroculi),
    hydro: toSafeNumber(stats?.hydroculi),
    pyro: toSafeNumber(stats?.pyroculi),
    luno: toSafeNumber(stats?.lunoculi),
};
---

<Layout title="Estadísticas de Genshin Impact">
    <Content>
        <h1 class="text-heading-page break-words">
            {nickname}, este es tu progreso
        </h1>
        <p class="text-muted-body mt-2 max-w-2xl">
            Datos principales, cofres y oculus en una sola vista.
        </p>

        <div class="mt-5 grid gap-6 lg:grid-cols-[minmax(0,19rem)_1fr]">
            <section class="surface-panel space-y-2 p-4 text-[15px]">
                <RowData icon="User" value={nickname} label="Jugador" />
                <RowData icon="Star" value={level} label="Nivel" />
                <RowData
                    icon="Calendar"
                    value={toSafeNumber(stats?.days_active)}
                    label="Días activos"
                />
                <RowData
                    icon="Award"
                    value={toSafeNumber(stats?.achievements)}
                    label="Logros"
                />
                <RowData
                    icon="Users"
                    value={toSafeNumber(stats?.characters)}
                    label="Personajes"
                />
                <RowData
                    icon="MapPin"
                    value={toSafeNumber(stats?.unlocked_waypoints)}
                    label="Teletransportes"
                />
                <RowData
                    icon="Map"
                    value={toSafeNumber(stats?.unlocked_domains)}
                    label="Dominios"
                />
                <RowData
                    icon="Shell"
                    value={String(stats?.spiral_abyss ?? "-")}
                    label="Abismo"
                />
            </section>

            <section class="space-y-3">
                <h3 class="text-heading-section">Cofres</h3>
                <Chests {...chests} />
            </section>
        </div>

        <section class="mt-8 space-y-3">
            <h3 class="text-heading-section">Oculus</h3>
            <Oculis {...oculis} />
        </section>
    </Content>
</Layout>
