---
import CharacterListPage from "@/components/CharacterListPage.astro";
import { getHsrCharacters } from "@/services/database";
import {
    HSR_ELEMENTS,
    HSR_ELEMENT_VISUALS,
    type HsrElement,
} from "@/utils/elements";

const characters = await getHsrCharacters();

const hsrElementLabels: Record<HsrElement, string> = {
    fire: "Fuego",
    ice: "Hielo",
    wind: "Viento",
    lightning: "Rayo",
    physical: "Físico",
    quantum: "Cuántico",
    imaginary: "Imaginario",
};

const presentElements = HSR_ELEMENTS.filter((el) =>
    characters.some((c) => c.element?.trim().toLowerCase() === el),
);

const rarities = [
    ...new Set(characters.map((c) => c.rarity ?? 0).filter(Boolean)),
].sort((a, b) => b - a);
---

<CharacterListPage
    title="Lista de personajes de Honkai: Star Rail"
    heading="Tus personajes de Honkai: Star Rail"
    description="Selecciona uno para ver nivel, eidolón, vía y cono de luz."
    emptyMessage="No encontramos personajes en tus datos de Honkai: Star Rail todavía. Actualiza el archivo e inténtalo de nuevo."
    characters={characters}
    basePath="/hsr/characters"
    presentElements={presentElements}
    rarities={rarities}
    elementLabels={hsrElementLabels}
    elementVisuals={HSR_ELEMENT_VISUALS}
    imageWidth={120}
    imageHeight={141}
    imageAspectRatioClass="aspect-[40/47]"
    imageClass="min-h-[141px] rounded-2xl"
/>
