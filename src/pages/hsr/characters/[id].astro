---
import Content from "@/layouts/Content.astro";
import Layout from "@/layouts/Layout.astro";
import Stars from "@/components/Stars.astro";
import LazyImage from "@/components/LazyImage.astro";
import RowData from "@/components/RowData.astro";
import { getHsrCharacters } from "@/services/database";
import { buildHsrCharacterDetailViewModel } from "@/services/hsr-character-detail";
import { type HsrCharacter } from "@/types";
import { Star } from "@lucide/astro";

interface Props {
    char: HsrCharacter;
}

export async function getStaticPaths() {
    const characters = await getHsrCharacters();

    return characters.map((char) => ({
        params: { id: String(char.id) },
        props: { char },
    }));
}

const { char } = Astro.props;

const preferredLocaleRaw = import.meta.env.PUBLIC_HSR_TERMS_LOCALE;
const {
    labels,
    safeName,
    safeIcon,
    safeRarity,
    safePath,
    safeElement,
    hasLightCone,
    lightConeName,
    lightConeIcon,
    lightConeRarity,
    memospriteName,
    memospriteIcon,
    levelText,
    rankText,
    lightConeLevelText,
    lightConeRankText,
} = buildHsrCharacterDetailViewModel(char, preferredLocaleRaw);
---

<Layout title={safeName}>
    <link slot="head" rel="preload" as="image" href={safeIcon} />
    <Content>
        <article class="mx-auto w-full max-w-4xl space-y-5">
            <header
                class="surface-panel flex flex-col items-center gap-3 p-5 text-center dark:text-slate-100"
            >
                <LazyImage
                    transitionName={`char-icon-${char.id}`}
                    class="rounded-2xl bg-slate-100 p-1 ring-1 ring-slate-300 dark:bg-slate-800 dark:ring-slate-700"
                    src={safeIcon}
                    alt={`${safeName} ${labels.avatarSuffix}`}
                    width={120}
                    height={141}
                    aspectRatioClass="aspect-[40/47]"
                    loading="eager"
                />

                <div class="flex flex-col items-center gap-1">
                    <h1
                        class="text-heading-page"
                        transition:name={`char-name-${char.id}`}
                    >
                        {safeName}
                    </h1>
                    <p class="text-muted-body text-sm">
                        {safeElement}
                    </p>
                </div>

                <Stars quantity={safeRarity} />
            </header>

            <section class="surface-panel space-y-2 p-4 text-[15px]">
                <RowData
                    icon="Gauge"
                    value={levelText}
                    label={labels.level}
                    variant="plain"
                />
                <RowData
                    icon="Sparkles"
                    value={`E${rankText}`}
                    label={labels.eidolon}
                    variant="plain"
                />
                <RowData
                    icon="Map"
                    value={safePath}
                    label={labels.path}
                    variant="plain"
                />
                <RowData
                    icon="Swords"
                    value={`${labels.level} ${lightConeLevelText}`}
                    label={labels.lightCone}
                    variant="plain"
                />
            </section>

            <section class="surface-panel p-4">
                <p class="text-muted-body text-sm">
                    {labels.equippedLightCone}
                </p>
                <div
                    class="mt-2 flex flex-col items-start gap-3 sm:flex-row sm:items-center"
                >
                    <LazyImage
                        class="h-14 w-14 shrink-0 rounded-lg bg-slate-100 p-1 ring-1 ring-slate-300 dark:bg-slate-800 dark:ring-slate-700"
                        src={lightConeIcon}
                        alt={`${lightConeName} ${labels.iconSuffix}`}
                        width={56}
                        height={56}
                    />
                    <div class="min-w-0">
                        <p
                            class="text-sm font-semibold text-slate-900 dark:text-slate-100 wrap-break-word"
                        >
                            {lightConeName}
                        </p>
                        {
                            hasLightCone && lightConeRarity > 0 && (
                                <div
                                    class="mt-1 flex items-center gap-0.5"
                                    role="img"
                                    aria-label={labels.lightConeRarity(lightConeRarity)}
                                >
                                    {Array.from(
                                        { length: lightConeRarity },
                                        () => (
                                            <Star
                                                size={14}
                                                class="text-yellow-500"
                                                aria-hidden="true"
                                            />
                                        ),
                                    )}
                                </div>
                            )
                        }
                        <p class="text-muted-body text-xs">
                            {labels.level}
                            {lightConeLevelText} · {lightConeRankText}
                        </p>
                    </div>
                </div>
            </section>

            {
                char.memosprite && (
                    <section class="surface-panel p-4">
                        <p class="text-muted-body text-sm">
                            {labels.memosprite}
                        </p>
                        <div class="mt-2 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
                            <LazyImage
                                class="h-12 w-12 shrink-0 rounded-lg bg-slate-100 p-1 ring-1 ring-slate-300 dark:bg-slate-800 dark:ring-slate-700"
                                src={memospriteIcon}
                                alt={`${memospriteName} ${labels.iconSuffix}`}
                                width={48}
                                height={48}
                            />
                            <p class="min-w-0 text-sm font-semibold text-slate-900 dark:text-slate-100 wrap-break-word">
                                {memospriteName}
                            </p>
                        </div>
                    </section>
                )
            }
        </article>
    </Content>
</Layout>
