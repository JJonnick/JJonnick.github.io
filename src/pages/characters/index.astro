---
import Layout from "@/layouts/Layout.astro";
import Content from "@/layouts/Content.astro";
import CardCharacter from "@/components/CardCharacter.astro";
import { getCharacters } from "@/services/database";

const characters = await getCharacters();
---

<Layout title="Lista de personajes">
    <Content>
        <h1 class="text-heading-page mb-1 text-xl">Tus personajes</h1>
        <p class="text-muted-body mb-5 max-w-2xl">
            Selecciona uno para ver nivel, constelación, amistad y arma.
        </p>

        {
            characters.length === 0 ? (
                <section class="surface-panel p-5 text-sm text-slate-700 dark:text-slate-200">
                    No encontramos personajes en tus datos todavía. Actualiza el
                    archivo e inténtalo de nuevo.
                </section>
            ) : (
                <div class="grid w-full grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 [content-visibility:auto] [contain-intrinsic-size:1px_1200px]">
                    {characters.map((item) => (
                        <CardCharacter
                            href={`/characters/${item.id}`}
                            char={item}
                        />
                    ))}
                </div>
            )
        }
    </Content>
</Layout>
