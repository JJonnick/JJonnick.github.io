---
import CharacterListPage from "@/components/CharacterListPage.astro";
import { getCharacters } from "@/services/database";
import { GENSHIN_ELEMENTS, type GenshinElement } from "@/utils/elements";

const characters = await getCharacters();

const elementLabels: Record<GenshinElement, string> = {
    anemo: "Anemo",
    geo: "Geo",
    electro: "Electro",
    dendro: "Dendro",
    hydro: "Hydro",
    pyro: "Pyro",
    cryo: "Cryo",
};

const presentElements = GENSHIN_ELEMENTS.filter((el) =>
    characters.some((c) => c.element?.trim().toLowerCase() === el),
);

const rarities = [
    ...new Set(characters.map((c) => c.rarity ?? 0).filter(Boolean)),
].sort((a, b) => b - a);
---

<CharacterListPage
    title="Lista de personajes"
    heading="Tus personajes"
    description="Selecciona uno para ver nivel, constelación, amistad y arma."
    emptyMessage="No encontramos personajes en tus datos todavía. Actualiza el archivo e inténtalo de nuevo."
    characters={characters}
    basePath="/characters"
    presentElements={presentElements}
    rarities={rarities}
    elementLabels={elementLabels}
    showElementIcons={true}
/>
