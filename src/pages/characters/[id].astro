---
import { Image } from "astro:assets";
import Content from "@/layouts/Content.astro";
import Layout from "@/layouts/Layout.astro";
import Stars from "@/components/Stars.astro";
import { getCharacters } from "@/services/database";
import { type Character } from "@/types/character";
import { Swords, Heart, Sparkles, Gauge } from "@lucide/astro";

interface Props {
    char: Character;
}

export async function getStaticPaths() {
    const characters = await getCharacters();

    return characters.map((char) => ({
        params: { id: char.id },
        props: { char },
    }));
}

const weaponTypeMap: Record<number, string> = {
    1: "Espada",
    10: "Catalizador",
    11: "Mandoble",
    12: "Arco",
    13: "Lanza",
};

const { char } = Astro.props;
const {
    id,
    icon,
    name,
    rarity,
    element,
    level,
    constellation,
    friendship,
    weapon_type,
} = char;
const toSafeNumber = (value: unknown): number => {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : 0;
};

const safeName = name?.trim() || "Personaje desconocido";
const safeElement = element?.trim() || "Elemento desconocido";
const safeIcon = icon || "/fallbacks/icon.svg";
const safeRarity = Math.min(5, Math.max(1, toSafeNumber(rarity) || 1));
const safeLevel = toSafeNumber(level);
const safeConstellation = toSafeNumber(constellation);
const safeFriendship = toSafeNumber(friendship);
const elementKey = safeElement.toLowerCase();
const safeElementIcon = [
    "anemo",
    "geo",
    "electro",
    "dendro",
    "hydro",
    "pyro",
    "cryo",
].includes(elementKey)
    ? `/elements/${elementKey}.svg`
    : "/fallbacks/icon.svg";
const weaponName = weaponTypeMap[weapon_type] ?? "Desconocido";
const statCardClass = "surface-panel p-3";
const statLabelClass = "text-muted-body text-xs";
const statValueClass =
    "text-lg font-semibold text-slate-900 dark:text-slate-100";
---

<Layout title={safeName}>
    <link slot="head" rel="preload" as="image" href={safeIcon} />
    <Content>
        <article class="mx-auto w-full max-w-4xl space-y-5">
            <header
                class="surface-panel flex flex-col items-center gap-3 p-5 text-center dark:text-slate-100"
            >
                <Image
                    transition:name={`char-icon-${id}`}
                    class="rounded-full bg-slate-100 p-1 ring-1 ring-slate-300 dark:bg-slate-800 dark:ring-slate-700"
                    src={safeIcon}
                    alt={`${safeName} avatar`}
                    width={120}
                    height={120}
                />

                <div class="flex items-center gap-2">
                    <h1
                        class="text-heading-page"
                        transition:name={`char-name-${id}`}
                    >
                        {safeName}
                    </h1>
                    <Image
                        class="rounded-full bg-slate-100 p-1 dark:bg-slate-800"
                        src={safeElementIcon}
                        alt={safeElement}
                        width={28}
                        height={28}
                    />
                </div>

                <Stars quantity={safeRarity} />
            </header>

            <section class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                <div
                    class={`flex flex-col items-center gap-1 ${statCardClass}`}
                >
                    <Gauge
                        size={20}
                        class="text-slate-600 dark:text-slate-300"
                    />
                    <span class={statLabelClass}>Nivel</span>
                    <span class={statValueClass}>{safeLevel}</span>
                </div>
                <div
                    class={`flex flex-col items-center gap-1 ${statCardClass}`}
                >
                    <Sparkles
                        size={20}
                        class="text-slate-600 dark:text-slate-300"
                    />
                    <span class={statLabelClass}>Constelación</span>
                    <span class={statValueClass}>C{safeConstellation}</span>
                </div>
                <div
                    class={`flex flex-col items-center gap-1 ${statCardClass}`}
                >
                    <Heart
                        size={20}
                        class="text-slate-600 dark:text-slate-300"
                    />
                    <span class={statLabelClass}>Amistad</span>
                    <span class={statValueClass}>{safeFriendship}</span>
                </div>
                <div
                    class={`flex flex-col items-center gap-1 ${statCardClass}`}
                >
                    <Swords
                        size={20}
                        class="text-slate-600 dark:text-slate-300"
                    />
                    <span class={statLabelClass}>Arma</span>
                    <span class={statValueClass}>{weaponName}</span>
                </div>
            </section>
        </article>
    </Content>
</Layout>
