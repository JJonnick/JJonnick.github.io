---
import HeaderButton from "./HeaderButton.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { House, Moon, Sun, Users } from "@lucide/astro";

const pathname = Astro.url.pathname;
const isHome = pathname === "/";
const isCharacters = pathname.startsWith("/characters");
---

<header
    class="sticky top-0 z-40 border-b border-slate-200/80 bg-slate-50/92 dark:border-slate-800 dark:bg-slate-950/88"
>
    <div
        class="mx-auto flex w-full max-w-6xl flex-wrap items-center justify-between gap-2 px-4 py-3"
    >
        <div class="min-w-0">
            <a
                href="/"
                class="text-lg font-semibold text-slate-900 dark:text-slate-100"
            >
                Genshin Impact
            </a>
            <p
                class="hidden text-xs text-slate-600 dark:text-slate-300 sm:block"
            >
                Consulta progreso de cuenta y personajes.
            </p>
        </div>

        <nav class="flex items-center gap-2" aria-label="Navegación principal">
            <HeaderButton href="/" isActive={isHome}>
                <House slot="before" size={17} />
                Inicio
            </HeaderButton>
            <HeaderButton href="/characters" isActive={isCharacters}>
                <Users slot="before" size={17} />
                Personajes
            </HeaderButton>
            <ThemeToggle>
                <Sun slot="sun" size={18} />
                <Moon slot="moon" size={18} />
            </ThemeToggle>
        </nav>
    </div>
</header>
