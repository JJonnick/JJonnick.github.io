---
import { icons } from "@lucide/astro";
import LucideIcon from "./LucideIcon.astro";
import CounterNumber from "./CounterNumber.astro";

interface Props {
    icon: keyof typeof icons;
    label?: string;
    value: string | number;
}

const { icon, value, label } = Astro.props;
const labelText = label ?? "Dato";
---

<div
    class="flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white/90 px-3 py-2 dark:border-slate-800 dark:bg-slate-950/40"
>
    <div class="flex min-w-0 items-center gap-2">
        <span
            class="inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-slate-200/85 text-slate-700 dark:bg-slate-700/50 dark:text-slate-100"
        >
            <LucideIcon name={icon} size={16} />
        </span>
        <span class="truncate text-sm text-slate-700 dark:text-slate-200"
            >{labelText}</span
        >
    </div>

    {
        typeof value === "number" ? (
            <span class="shrink-0 text-base font-bold text-slate-900 dark:text-slate-50 tabular-nums">
                <CounterNumber value={value} />
            </span>
        ) : (
            <span class="min-w-0 max-w-[55%] break-words text-right text-sm font-semibold text-slate-900 dark:text-slate-50">
                {value}
            </span>
        )
    }
</div>
