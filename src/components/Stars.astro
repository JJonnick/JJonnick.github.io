---
import { Star } from "@lucide/astro";

interface Props {
    quantity: number;
}

const { quantity } = Astro.props;
const starsLabel = `${quantity} ${quantity === 1 ? "estrella" : "estrellas"}`;
---

<div
    class="flex flex-row items-center justify-center gap-1 py-2"
    role="img"
    aria-label={`Rareza: ${starsLabel}`}
>
    {
        Array.from({ length: quantity }, () => (
            <Star size={18} class="text-yellow-500" aria-hidden="true" />
        ))
    }
</div>
