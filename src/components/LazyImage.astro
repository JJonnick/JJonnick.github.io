---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  aspectRatioClass?: string;
  class?: string;
  transitionName?: string;
  loading?: "lazy" | "eager";
}

const {
  src,
  alt,
  width,
  height,
  aspectRatioClass = "aspect-square",
  class: className,
  transitionName,
  loading = "lazy",
} = Astro.props;
---

<span
  class:list={["relative inline-block", aspectRatioClass]}
  style={`width:${width}px`}
>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class:list={[
      className,
      "h-full w-full object-contain [content-visibility:auto]",
      "opacity-0 transition-opacity duration-200",
    ]}
    transition:name={transitionName}
    loading={loading}
    decoding="async"
    onload="this.style.opacity='1'; const skeletonOnLoad=this.nextElementSibling; if (skeletonOnLoad) skeletonOnLoad.classList.add('hidden');"
    onerror="this.style.display='none'; const skeletonOnError=this.nextElementSibling; if (skeletonOnError) skeletonOnError.classList.remove('hidden');"
  />
  <span
    aria-hidden="true"
    class:list={[
      className,
      "absolute inset-0 animate-pulse pointer-events-none bg-slate-200 dark:bg-slate-700",
    ]}></span>
</span>
