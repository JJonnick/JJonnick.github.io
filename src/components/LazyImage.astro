---
interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  class?: string;
  transitionName?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: className,
  transitionName,
} = Astro.props;
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  class:list={[className, "[content-visibility:auto]"]}
  transition:name={transitionName}
  loading="lazy"
/>
