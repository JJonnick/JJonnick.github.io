---
import { Image } from "astro:assets";
import { type ImageMetadata } from "astro";
import CounterNumber from "./CounterNumber.astro";

interface Props {
    quantity: number;
    image: ImageMetadata;
    label: string;
}

const { quantity, image, label } = Astro.props;
---

<article
    class="surface-panel surface-lift-soft group flex flex-col items-center justify-center gap-2 p-4 shadow-[0_8px_18px_-18px_rgba(30,41,59,0.4)]"
>
    <Image
        src={image}
        height={80}
        width={80}
        alt={label}
        class="surface-media-pop"
    />
    <span
        class="text-xs font-medium uppercase tracking-[0.12em] text-slate-700 dark:text-slate-200"
        >{label}</span
    >
    <CounterNumber
        value={quantity}
        class="text-2xl font-extrabold text-slate-900 dark:text-slate-50 tabular-nums"
    />
</article>
