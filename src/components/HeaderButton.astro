---
interface Props {
    href: string;
    isActive?: boolean;
    className?: string;
}

const { href, isActive = false, className = "" } = Astro.props;
---

<a
  href={href}
  class:list={["ui-control", isActive ? "ui-control-active" : "ui-control-idle", className, "whitespace-nowrap"]}
  aria-current={isActive ? "page" : undefined}
>
    <span class="shrink-0">
        <slot name="before" />
    </span>
    <span>
        <slot />
    </span>
</a>
