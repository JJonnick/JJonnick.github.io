---
interface Props {
    href: string;
    isActive?: boolean;
}

const { href, isActive = false } = Astro.props;
const buttonClass = `ui-control ${
    isActive ? "ui-control-active" : "ui-control-idle"
}`;
---

<a href={href} class={buttonClass} aria-current={isActive ? "page" : undefined}>
    <span class="shrink-0">
        <slot name="before" />
    </span>
    <span>
        <slot />
    </span>
</a>
