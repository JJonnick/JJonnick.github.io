---
import { Image } from "astro:assets";
import { type ImageMetadata } from "astro";
import CounterNumber from "./CounterNumber.astro";

interface Props {
    quantity: number;
    image: ImageMetadata;
    label: string;
}

const { quantity, image, label } = Astro.props;
---

<article
    class="surface-panel surface-lift-soft group p-5 shadow-[0_8px_20px_-20px_rgba(30,41,59,0.4)]"
>
    <div class="flex items-center justify-between gap-4">
        <div class="space-y-1">
            <span
                class="block text-xs font-medium uppercase tracking-[0.13em] text-slate-700 dark:text-slate-200"
                >{label}</span
            >
            <CounterNumber
                value={quantity}
                class="text-3xl font-extrabold text-slate-900 dark:text-slate-50 tabular-nums"
            />
        </div>

        <Image
            src={image}
            height={80}
            width={80}
            alt={label}
            class="surface-media-pop"
        />
    </div>
</article>
