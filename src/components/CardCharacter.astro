---
import LazyImage from "./LazyImage.astro";
import { type Character } from "@/types/character";

interface Props {
  href: string;
  char: Character;
}

const { href, char } = Astro.props;
---

<a
  href={href}
  data-scroll-card
  class="surface-card-interactive group flex flex-col items-center justify-center p-5"
>
  <div class="flex flex-col items-center gap-4">
    <LazyImage
      transitionName={`char-icon-${char.id}`}
      class="min-h-[100px] rounded-full"
      src={char.icon}
      alt={char.name}
      width={120}
      height={120}
    />
    <h3
      class="max-w-full break-words text-center text-lg font-semibold leading-snug text-slate-900 dark:text-slate-100"
      transition:name={`char-name-${char.id}`}
    >
      {char.name}
    </h3>
  </div>
</a>
