---
import LazyImage from "./LazyImage.astro";
import {
  GENSHIN_ELEMENT_VISUALS,
  type ElementVisual,
} from "@/utils/elements";

interface Props {
  href: string;
  char: {
    id: number | string;
    icon: string;
    name: string;
    element?: string;
    rarity?: number;
  };
  imageWidth?: number;
  imageHeight?: number;
  imageAspectRatioClass?: string;
  imageClass?: string;
  elementVisuals?: Partial<Record<string, ElementVisual>>;
}

const {
  href,
  char,
  imageWidth = 120,
  imageHeight = 120,
  imageAspectRatioClass = "aspect-square",
  imageClass = "min-h-25 rounded-full",
  elementVisuals = GENSHIN_ELEMENT_VISUALS as Partial<Record<string, ElementVisual>>,
} = Astro.props;

const elementKey =
  typeof char.element === "string" ? char.element.trim().toLowerCase() : "";
const elementVisual = elementKey ? elementVisuals[elementKey] : undefined;
---

<a
  href={href}
  class="surface-card-interactive group flex flex-col items-center justify-center p-5"
>
  <div class="flex flex-col items-center gap-4">
    <div class="relative inline-block">
      <LazyImage
        transitionName={`char-icon-${char.id}`}
        class={imageClass}
        src={char.icon}
        alt={char.name}
        width={imageWidth}
        height={imageHeight}
        aspectRatioClass={imageAspectRatioClass}
      />
      {
        elementVisual && (
          <img
            src={elementVisual.iconPath}
            alt=""
            aria-hidden="true"
            width={22}
            height={22}
            class="absolute -right-1.5 -bottom-1.5 rounded-full border border-white/60 dark:border-slate-900/60"
            style={`background: ${elementVisual.badgeBg}; padding: 2px`}
          />
        )
      }
    </div>
    <h3
      class="max-w-full wrap-break-word text-center text-lg font-semibold leading-snug text-slate-900 dark:text-slate-100"
      transition:name={`char-name-${char.id}`}
    >
      {char.name}
    </h3>
  </div>
</a>
