---
import LazyImage from "./LazyImage.astro";
import {
  GENSHIN_ELEMENTS,
  type GenshinElement,
  elementAccentColor,
  elementBadgeBg,
  elementGlow,
} from "@/utils/elements";

interface Props {
  href: string;
  char: {
    id: number | string;
    icon: string;
    name: string;
    element?: string;
    rarity?: number;
  };
  imageWidth?: number;
  imageHeight?: number;
  imageAspectRatioClass?: string;
  imageClass?: string;
}

const {
  href,
  char,
  imageWidth = 120,
  imageHeight = 120,
  imageAspectRatioClass = "aspect-square",
  imageClass = "min-h-25 rounded-full",
} = Astro.props;

const elementKey =
  typeof char.element === "string" ? char.element.trim().toLowerCase() : "";
const hasElement = (GENSHIN_ELEMENTS as readonly string[]).includes(elementKey);
const el = hasElement ? (elementKey as GenshinElement) : null;
const elementIconPath = el ? `/elements/${el}.svg` : null;

const accentColor = el ? elementAccentColor(el) : "";
const badgeBg = el ? elementBadgeBg(el) : "";
const badgeGlow = el ? elementGlow(el) : "";

const rarity = char.rarity ?? 0;
const rarityBorderStyle =
  rarity === 5
    ? "border-color: rgba(251,191,36,0.45)"
    : rarity === 4
      ? "border-color: rgba(167,139,250,0.45)"
      : "";
---

<a
  href={href}
  data-scroll-card
  class="surface-card-interactive group relative flex flex-col overflow-hidden p-0"
  style={rarityBorderStyle}
>
  {
    el && (
      <div
        class="h-0.5 w-full shrink-0"
        style={`background-color: ${accentColor}`}
        aria-hidden="true"
      />
    )
  }
  <div class="flex flex-col items-center gap-3 p-5">
    <div class="relative inline-block">
      <LazyImage
        transitionName={`char-icon-${char.id}`}
        class={imageClass}
        src={char.icon}
        alt={char.name}
        width={imageWidth}
        height={imageHeight}
        aspectRatioClass={imageAspectRatioClass}
      />
      {
        elementIconPath && (
          <img
            src={elementIconPath}
            alt=""
            aria-hidden="true"
            width={22}
            height={22}
            class="absolute -right-1.5 -bottom-1.5 rounded-full border border-white/60 dark:border-slate-900/60"
            style={`background: ${badgeBg}; box-shadow: ${badgeGlow}; padding: 2px`}
          />
        )
      }
    </div>
    <h3
      class="max-w-full wrap-break-word text-center text-lg font-semibold leading-snug text-slate-900 dark:text-slate-100"
      transition:name={`char-name-${char.id}`}
    >
      {char.name}
    </h3>
  </div>
</a>
