---
interface Props {
    value: number;
    class?: string;
}

const { value, class: className = '' } = Astro.props;
const normalizedValue = Math.round(value);
---

<span
    class:list={['counter-num', className]}
    style={`--target: ${normalizedValue}`}
    aria-hidden="true"
></span>
<span class="sr-only">{normalizedValue}</span>
